---
import BackToMain from './BackToMain.astro';

const { t } = Astro.props;
---

<div id="success-message" class="success-message text-center p-8 bg-[#606c38] text-white rounded-lg" style="display: none;">
  <h2 class="text-3xl font-bold text-white mb-2">{t.successTitle}</h2>
  <p id="success-text"></p>
  <BackToMain t={t} />
</div>

<div id="submitted-summary" class="summary-section" style="display: none;">
  <div class="text-center mb-8">
    <h2 class="text-2xl font-serif text-gray-800 mb-2">{t.alreadyResponded}</h2>
    <p class="text-gray-600">{t.yourResponse}</p>
  </div>
  
  <div class="bg-stone-50 rounded-lg p-6 mb-6">
    <div class="mb-4">
      <p class="text-sm text-gray-500">{t.attending}</p>
      <p id="summary-attending" class="text-lg font-medium text-gray-800"></p>
    </div>
    
    <div class="mb-4">
      <p class="text-sm text-gray-500">{t.dietaryRequirements}</p>
      <p id="summary-dietary" class="text-gray-800"></p>
    </div>
    
    <div class="mb-4">
      <p class="text-sm text-gray-500">{t.allergies}</p>
      <p id="summary-allergies" class="text-gray-800"></p>
    </div>
    
    <div class="mb-4">
      <p class="text-sm text-gray-500">{t.transportNeeded}</p>
      <p id="summary-transport" class="text-gray-800"></p>
    </div>
    
    <div id="summary-plus-one-container" class="mb-4" style="display: none;">
      <p class="text-sm text-gray-500">{t.plusOneAttending}</p>
      <p id="summary-plus-one" class="text-gray-800"></p>
    </div>
  </div>
  
  <div class="bg-stone-50 rounded-lg p-6 mb-6">
    <h3 class="text-lg font-serif mb-4 text-gray-800">{t.venueInfo}</h3>
    <p class="text-gray-700 font-medium" id="summary-venue-name"></p>
    <p class="text-gray-600" id="summary-venue-address"></p>
    <p class="text-gray-600" id="summary-venue-city"></p>
  </div>
  
  <div id="contact-email-note" style="display: none;">
    <p class="text-center text-gray-600">
      {t.contactEmailText}
    </p>
    <p class="text-center">
      <a href="mailto:info@gemma-bastiaan.wedding" class="text-[#c9a66b] hover:underline">info@gemma-bastiaan.wedding</a>
    </p>
  </div>

  <BackToMain t={t} />
</div>

<div id="error-message" class="error-message text-center p-4 bg-[#c1121f] text-white rounded-lg mt-4" style="display: none;">
  <p id="error-text"></p>
</div>

---
const { t } = Astro.props;
---

<div class="form-section mb-8 pb-6 border-b border-gray-100" id="transport-section" style="display: none;">
  <h2 class="text-xl font-serif mb-2 text-gray-800">{t.transportTitle}</h2>
  <p class="text-sm text-gray-500 mb-1">Address:</p>
  <p class="text-sm text-gray-500 mb-4">{t.transportVenueAddress}</p>
  <label class="checkbox-label cursor-pointer flex items-center gap-3 p-4 rounded-lg hover:bg-stone-50 transition-colors">
    <input type="checkbox" name="needs_transport" id="needs-transport" class="w-5 h-5 accent-[#c9a66b]" />
    <span class="text-gray-700">{t.transportCheckbox}</span>
  </label>
</div>

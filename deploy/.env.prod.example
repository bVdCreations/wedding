# Images (use c-<hash> tags for specific versions, defaults to latest)
API_IMAGE=ghcr.io/bvdcreations/wedding-api:latest
API_IMAGE_BASE=ghcr.io/bvdcreations/wedding-api
WEBHOOK_IMAGE=ghcr.io/bvdcreations/wedding-webhook:latest

# Can optionally use c-latest for commit-based tags:
# API_IMAGE=ghcr.io/bvdcreations/wedding-api:c-latest
# WEBHOOK_IMAGE=ghcr.io/bvdcreations/wedding-webhook:c-latest

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
FRONTEND_URL=https://your-domain.com
ENVIRONMENT=Production
SECRET_KEY=generate_a_secure_random_secret_key

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=wedding_rsvp
DATABASE_URL=postgresql+asyncpg://postgres:change_this_password_in_production@db:5432/wedding_rsvp

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAILS_FROM=info@your-domain.com

# Email (Resend) - uncomment if using Resend API instead of SMTP
# RESEND_API_KEY=re_123456789

# Resend email forwarding
# FORWARD_TO_EMAILS=you@example.com

# Resend webhooks
# RESEND_WEBHOOK_SECRET=whsec_...

# Sentry
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# PostHog
# PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
# PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Webhook
WEBHOOK_SECRET=change_this_to_a_secure_random_token

# Cloudflare (for DNS-01 challenge with Caddy)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token